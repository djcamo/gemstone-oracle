<header
    class="sticky top-0 z-40 glass border-b border-white/5"
    data-testid="site-header"
>
    <div
        class="max-w-6xl mx-auto px-5 md:px-10 h-16 flex items-center justify-between"
    >
        <div class="flex items-center gap-3">
            <a
                class="flex items-center gap-2"
                data-testid="logo-home-link"
                href="/"
                data-discover="true"
                ><svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="lucide lucide-sparkles text-[#d4af37]"
                    aria-hidden="true"
                    ><path
                        d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"
                    ></path><path d="M20 3v4"></path><path d="M22 5h-4"
                    ></path><path d="M4 17v2"></path><path d="M5 18H3"
                    ></path></svg
                ><span class="font-serif-display text-xl tracking-wide"
                    ></span
                ></a>
        </div><nav class="flex items-center gap-5">
            <a
                class="flex items-center gap-2 text-sm tracking-[0.15em] uppercase text-white/60 hover:text-[#d4af37] transition-colors"
                data-testid="nav-browse"
                href="/browse"
                data-discover="true"
                >
                <img
                    src="/images/folder.svg"
                    alt="Browse gemstones"
                    class="w-3.5 h-3.5 filter invert">
                <span class="hidden sm:inline">Browse</span></a>
            <a
                class="flex items-center gap-2 text-sm tracking-[0.15em] uppercase text-white/60 hover:text-[#d4af37] transition-colors"
                data-testid="nav-favorites"
                href="/favorites"
                data-discover="true"
                ><svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="15"
                    height="15"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="lucide lucide-heart"
                    aria-hidden="true"
                    ><path
                        d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"
                    ></path></svg
                ><span class="hidden sm:inline">Favorites</span></a>
        </nav>
    </div>
</header>
